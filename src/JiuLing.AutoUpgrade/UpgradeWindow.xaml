<Window x:Class="JiuLing.AutoUpgrade.UpgradeWindow"
        x:Name="Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:props="clr-namespace:JiuLing.AutoUpgrade.Properties"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{x:Static props:Resources.Title}" 
        Height="450" 
        Width="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="UpgradeWindow_Loaded"
        MouseLeftButtonDown="UpgradeWindow_MouseLeftButtonDown"
        Closing="UpgradeWindow_Closing"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True">

    <Grid>
        <!-- 全局文字颜色继承 ModernWpf Brush -->
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="TextElement.Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>
        </Grid.Style>

        <Grid.RowDefinitions>
            <!-- 自绘标题栏 -->
            <RowDefinition Height="{Binding Path=(ui:TitleBar.Height), RelativeSource={RelativeSource AncestorType=Window}}" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏 -->
        <Grid x:Name="AppTitleBar"
              Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <TextBlock Margin="10,0,0,0"
                       x:Name="TxtTitle"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       FontSize="14"/>
        </Grid>

        <!-- 内容区 -->
        <Grid Grid.Row="1"
              Margin="10,20,10,5"
              Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- 更新详情面板 -->
            <StackPanel Grid.Row="0"
                        x:Name="PanelUpdateDetail">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" 
                           Text="{x:Static props:Resources.NewVersionFound}" 
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*"/>
                        <ColumnDefinition Width="50*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧信息 -->
                    <StackPanel Grid.Column="0" Margin="20,20,30,0">
                        <StackPanel Orientation="Horizontal">
                            <Label Width="140" Content="{x:Static props:Resources.NewVersion}"/>
                            <TextBlock x:Name="LblVersion"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Width="140" IsEnabled="False" Content="{x:Static props:Resources.Size}"/>
                            <TextBlock x:Name="LblSize"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Width="140" IsEnabled="False" Content="{x:Static props:Resources.ReleaseTime}"/>
                            <TextBlock x:Name="LblTime"/>
                        </StackPanel>

                        <Separator Margin="0,25,0,25"/>

                        <StackPanel Orientation="Horizontal">
                            <Label Width="140" IsEnabled="False" Content="{x:Static props:Resources.CurrentVersion}"/>
                            <TextBlock x:Name="LblCurrentVersion"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧更新内容 -->
                    <StackPanel Grid.Column="1" Margin="30,0,20,0">
                        <TextBlock Text="{x:Static props:Resources.UpdateContent}" 
                                   Margin="0,0,0,20"
                                   Opacity="0.6"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="220">
                            <TextBlock x:Name="TxtLog" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 更新中面板 -->
            <StackPanel Grid.Row="0"
                        x:Name="PanelDoUpdate"
                        Visibility="Hidden"
                        Width="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           Text="{x:Static props:Resources.Updating}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           x:Name="TxtPercent" />
                <ProgressBar Margin="0,0,0,10"
                             x:Name="ProgressBarPercent" 
                             Minimum="0"
                             Maximum="1"
                             Height="2"
                             IsIndeterminate="False"/>
                <ProgressBar IsIndeterminate="True"/>
            </StackPanel>

            <!-- 消息面板 -->
            <StackPanel Grid.Row="0"
                        x:Name="PanelMessage"
                        Width="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Hidden">
                <TextBlock x:Name="TxtMessage"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- 底部按钮 -->
            <Grid Grid.Row="1"
                  VerticalAlignment="Bottom"
                  Height="30">
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Bottom">
                    <TextBlock x:Name="TxtWarn"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               Text="{x:Static props:Resources.ProgramExpired}"
                               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button x:Name="BtnSkip"
                            Content="{x:Static props:Resources.Skip}"
                            Click="BtnSkip_Click"
                            Style="{StaticResource DefaultButtonStyle}" />
                    <Button x:Name="BtnUpgrade"
                            Content="{x:Static props:Resources.Update}"
                            Click="BtnUpgrade_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Margin="10,0,0,0"/>
                    <Button x:Name="BtnCancel"
                            Content="{x:Static props:Resources.Close}"
                            Click="BtnCancel_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
